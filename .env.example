
# Get a Google OAuth Client ID: https://console.cloud.google.com/apis/credentials

# Google Sign-In (required for "Continue with Google")
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com

# Server
# PORT=3000
# NODE_ENV=development

# PostgreSQL (required). Create a database first, e.g.: createdb bodybank
DATABASE_URL=postgresql://localhost:5432/bodybank
# Or with username/password: postgresql://username:password@localhost:5432/bodybank

# For one-time migration from SQLite: point to your existing SQLite file, then run node scripts/migrate-sqlite-to-postgres.js
# DB_PATH=data/bodybank.db

# Admin login (defaults: admin@bodybank.fit / admin123)
# ADMIN_EMAIL=admin@bodybank.fit
# ADMIN_PASS=your_admin_password
# In production you MUST set ADMIN_PASS to a strong password (default is refused).

# Superadmin (business overview dashboard; defaults: superadmin@bodybank.fit / superadmin123)
# SUPERADMIN_EMAIL=superadmin@bodybank.fit
# SUPERADMIN_PASS=your_superadmin_password
# In production you MUST set both; default SUPERADMIN_PASS is refused.

# Auth (production: set a long random string for JWT and share links)
# JWT_SECRET=your-long-random-secret

# Optional: base URL for superadmin "Share via link" (defaults to request host)
# PUBLIC_URL=https://your-app.onrender.com

# Optional CORS (production)
# ALLOWED_ORIGIN=https://yoursite.com

# Admin AI Assist: for rich, actionable answers and suggestions based on your data (optional)
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# Push notifications: generate with npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=your_public_key
# VAPID_PRIVATE_KEY=your_private_key

# Scheduled messages & streak reminder cron: set a secret so only your cron service can trigger jobs.
# Required on Render free tier (server sleeps) — use cron-job.org or UptimeRobot to hit:
#   https://your-app.onrender.com/api/cron/process-scheduled-messages?secret=YOUR_CRON_SECRET
#   every 5–10 minutes.
#   https://your-app.onrender.com/api/cron/streak-reminder?secret=YOUR_CRON_SECRET
#   daily at 6 PM (or evening) to remind users to save check-in and keep streak.
# CRON_SECRET=your_long_random_secret
