PORT=3200
DATABASE_URL=postgresql://USER:PASS@127.0.0.1:5432/DBNAME
JWT_SECRET=change-me-in-production
# Access-token lifetime (jsonwebtoken: 7d, 30d, 365d, 12h). Optional; Nest defaults to 365d if unset.
# JWT_EXPIRY=365d
# Bootstrap + login: creates/updates superadmin on startup and on login
SUPERADMIN_EMAIL=you@example.com
SUPERADMIN_PASS=YourSecurePass123
# Optional fallback (also works without env): superadmin@gmail.com / Fitbase@2026
#
# Web Push (PWA banners + icon badge) — run: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
