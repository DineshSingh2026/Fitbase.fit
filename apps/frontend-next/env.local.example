# Copy to .env.local for local Next + Nest (same DB as backend).
# Next rewrites /api/* → BACKEND_URL (see next.config.mjs).
BACKEND_URL=http://127.0.0.1:3200
# Optional build-time fallback; in the browser the app uses window.location.origin
# so https://www.fitbase.fit always hits /api on that host (same DB as BACKEND_URL).
NEXT_PUBLIC_APP_SITE_URL=http://127.0.0.1:3102
