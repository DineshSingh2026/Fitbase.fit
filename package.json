{
  "name": "fitbase",
  "version": "1.0.0",
  "description": "FitBase — Lifestyle Management Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "dev:local": "concurrently -k -n api,web -c blue,magenta \"npm run dev\" \"npm --prefix apps/frontend-next run dev:stack\"",
    "dev:frontend-next": "npm --prefix apps/frontend-next run dev",
    "dev:backend-nest": "npm --prefix apps/backend-nest run dev",
    "setup:google": "node scripts/setup-google-signin.js",
    "migrate": "node scripts/migrate-sqlite-to-postgres.js",
    "test": "node scripts/ensure-password-resets-table.js && node tests/e2e-flow.js",
    "test:e2e:connect": "node tests/e2e-connectivity.js",
    "test:e2e:playwright": "playwright test",
    "build:pwa-icons": "node scripts/generate-pwa-icons.js",
    "clean-e2e": "node scripts/clean-e2e-data.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "google-auth-library": "^10.3.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.2",
    "pg": "^8.18.0",
    "uuid": "^11.1.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "concurrently": "^9.1.2",
    "sharp": "^0.34.5",
    "sql.js": "^1.14.0"
  }
}
